{
  "name": "@banana/tokens",
  "version": "0.1.0",
  "description": "Neo-Brutalist design tokens (DTCG) with CSS + TypeScript outputs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./dtcg": "./src/tokens"
  },
  "files": ["dist", "src/tokens"],
  "scripts": {
    "generate": "node build.mjs",
    "build": "node build.mjs && tsup",
    "typecheck": "node build.mjs && tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
