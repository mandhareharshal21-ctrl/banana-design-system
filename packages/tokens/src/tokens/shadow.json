{
  "shadow": {
    "hard": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "color": "{color.ink}",
          "offsetX": "2px",
          "offsetY": "2px",
          "blur": "0px",
          "spread": "0px"
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "color": "{color.ink}",
          "offsetX": "4px",
          "offsetY": "4px",
          "blur": "0px",
          "spread": "0px"
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "color": "{color.ink}",
          "offsetX": "6px",
          "offsetY": "6px",
          "blur": "0px",
          "spread": "0px"
        }
      }
    }
  }
}
