          "hex": "#000000"
        },
        "strokeWeight": 3,
        "shadow": {
          "x": 4,
          "y": 4,
          "color": "#000000"
        },
        "width": 320,
        "fixedWidth": true,
        "fixedHeight": false,
        "children": [
